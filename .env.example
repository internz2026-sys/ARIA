# ─── Claude API ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Model + Rate Limits ───
# Model to use (default: claude-sonnet-4-20250514)
ARIA_MODEL=claude-sonnet-4-20250514
# Per-tenant hourly limits (adjust based on your plan)
ARIA_HOURLY_REQUEST_LIMIT=60
ARIA_HOURLY_TOKEN_LIMIT=200000

# ─── Voice AI ───
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis ───
REDIS_URL=redis://default:...@your-redis.upstash.io:6379

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Google OAuth (Gmail API sending) ───
# Same credentials as your Supabase Google provider config
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SendGrid ───
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=hello@aria.ai

# ─── Lead Data ───
APOLLO_API_KEY=
HUNTER_API_KEY=

# ─── Twilio (WhatsApp + SMS) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+1234567890

# ─── Slack ───
SLACK_WEBHOOK_URL=

# ─── Frontend (Next.js public vars) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set to your deployed backend URL (e.g. https://aria-backend.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8000
