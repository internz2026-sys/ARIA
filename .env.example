# ─── Claude API ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Model + Rate Limits ───
# Model to use (default: claude-sonnet-4-20250514)
ARIA_MODEL=claude-sonnet-4-20250514
# Per-tenant hourly limits (adjust based on your plan)
ARIA_HOURLY_REQUEST_LIMIT=60
ARIA_HOURLY_TOKEN_LIMIT=200000

# ─── Voice AI ───
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT auth — supports both legacy (HS256) and new ECC (ES256) keys
# Legacy: Supabase > Settings > API > Legacy JWT Secret
SUPABASE_JWT_SECRET=
# ECC/ES256: Supabase > Settings > API > JWT Signing Keys > Current Key (JSON format)
SUPABASE_JWT_ECC_PUBLIC_KEY=

# ─── Redis ───
REDIS_URL=redis://default:...@your-redis.upstash.io:6379

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Google OAuth (Gmail API sending) ───
# Same credentials as your Supabase Google provider config
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SendGrid ───
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=hello@aria.ai

# ─── Lead Data ───
APOLLO_API_KEY=
HUNTER_API_KEY=

# ─── WhatsApp Cloud API (Meta) ───
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=aria-whatsapp-verify

# ─── LinkedIn ───
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Twilio (SMS fallback) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+1234567890

# ─── Slack ───
SLACK_WEBHOOK_URL=

# ─── Frontend (Next.js public vars) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set to your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── CORS ───
# Comma-separated list of allowed origins for both REST and Socket.IO
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Operating mode ───
# When set to "production"|"prod", activates fail-closed paths:
# - Webhooks return 503 if their signing secret isn't set
# - /docs and /openapi.json are disabled
# - Error messages return correlation IDs instead of stack traces
# Leave unset / set to "dev" for local development.
ARIA_ENV=production

# ─── Paperclip orchestration ───
PAPERCLIP_API_URL=https://your-paperclip-host
PAPERCLIP_API_TOKEN=
PAPERCLIP_SESSION_COOKIE=

# Per-agent Bearer tokens — generated in Paperclip's UI under each
# agent's Configuration → API Keys.
PAPERCLIP_CEO_KEY=
PAPERCLIP_CONTENT_WRITER_KEY=
PAPERCLIP_EMAIL_MARKETER_KEY=
PAPERCLIP_SOCIAL_MANAGER_KEY=
PAPERCLIP_AD_STRATEGIST_KEY=
PAPERCLIP_MEDIA_KEY=

# Paperclip-side identifiers (UUIDs). Previously hardcoded as fallbacks
# in backend/orchestrator.py; moved to .env 2026-05-06 so production-
# specific identifiers don't sit in source.
PAPERCLIP_COMPANY_ID=
PAPERCLIP_CEO_AGENT_ID=
PAPERCLIP_CONTENT_WRITER_AGENT_ID=
PAPERCLIP_EMAIL_MARKETER_AGENT_ID=
PAPERCLIP_SOCIAL_MANAGER_AGENT_ID=
PAPERCLIP_AD_STRATEGIST_AGENT_ID=
PAPERCLIP_MEDIA_AGENT_ID=

# ─── Email providers ───
# Default outbound provider: smtp | gmail | auto
EMAIL_PROVIDER=smtp

# SMTP — the default provider. Works against any standard SMTP server
# (Hostinger, Gmail SMTP with App Password, AWS SES SMTP, etc.).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# "true" = SMTPS / port 465. "false" = STARTTLS / port 587.
SMTP_USE_SSL=true
SMTP_USER=aria@your-domain.com
SMTP_PASSWORD=
# What recipients see in the From header. Must be the same address as
# SMTP_USER for Hostinger (and most SMTP servers reject mismatches).
SMTP_FROM_EMAIL=aria@your-domain.com
SMTP_FROM_NAME=ARIA

INBOUND_EMAIL_DOMAIN=inbound.your-domain.com
INBOUND_EMAIL_PROVIDER=postmark

# Inbound webhook signing — MUST be set in production. Same value also
# configured in Postmark/Resend dashboard so signed POSTs validate.
INBOUND_WEBHOOK_SECRET=

# Optional — only set if you actually use these inbound providers
# SENDGRID_WEBHOOK_VERIFICATION_KEY=
# SHOPIFY_WEBHOOK_SECRET=

# ─── Internal agent token ───
# Shared secret the Paperclip Media Designer uses to authenticate its
# call to /api/media/.../generate. Same value must be set in the
# `aria-backend-api` skill's SKILL.md inside Paperclip.
ARIA_INTERNAL_AGENT_TOKEN=

# ─── AI / image generation ───
# Only needed if you want Gemini-backed image generation
GEMINI_API_KEY=

# ─── Qdrant (vector DB) ───
QDRANT_URL=http://qdrant:6333

# ─── Login rate limiter (optional overrides) ───
# LOGIN_ATTEMPT_EMAIL_LIMIT=5
# LOGIN_ATTEMPT_IP_LIMIT=20
# LOGIN_ATTEMPT_WINDOW_SECONDS=900

# ─── API docs gate ───
# Flip to "true" to expose /docs and /openapi.json in production
# (default: hidden in production, exposed in dev)
# ENABLE_API_DOCS=false
