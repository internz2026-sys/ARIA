# ─── Playwright test artifacts ─────────────────────────────────────────────
# Screenshots from the playwright-tester subagent + ad-hoc Playwright MCP
# runs accumulate quickly. Keep them out of git unless explicitly needed
# for a PR (in which case commit individually with `git add -f`).
# We ignore the contents but keep the directory tracked via .gitkeep.
tests/playwright/screenshots/*
!tests/playwright/screenshots/.gitkeep
.playwright-mcp/

# ─── Misc ──────────────────────────────────────────────────────────────────
*.tmp
*.bak

# Local-only / build noise (added 2026-05-15)
.mcp.json
pytest_err.txt
pytest_out.txt
*.pptx
*.mp4
